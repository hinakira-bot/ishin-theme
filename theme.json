{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1120px"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{ "slug": "sumi",       "color": "#1f1f1f", "name": "墨 (sumi) — 文字色" },
				{ "slug": "nibi",       "color": "#5a5a5a", "name": "鈍 (nibi) — サブ文字" },
				{ "slug": "haiiro",     "color": "#9a9a9a", "name": "灰色 (haiiro) — 説明文" },
				{ "slug": "ginnezu",    "color": "#d4d2cc", "name": "銀鼠 (ginnezu) — 境界線" },
				{ "slug": "kinari",     "color": "#f5f1e8", "name": "生成り (kinari) — 余白" },
				{ "slug": "shironeri",  "color": "#fbf9f4", "name": "白練 (shironeri) — 背景" },
				{ "slug": "shu",        "color": "#c72e2e", "name": "朱 (shu) — アクセント" },
				{ "slug": "ai",         "color": "#3b5c7a", "name": "藍 (ai) — リンク" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Noto Sans JP', 'Hiragino Sans', 'Yu Gothic', system-ui, sans-serif",
					"slug": "gothic",
					"name": "ゴシック (標準)"
				},
				{
					"fontFamily": "'Noto Serif JP', 'Yu Mincho', 'Hiragino Mincho ProN', serif",
					"slug": "mincho",
					"name": "明朝 (和テイスト)"
				},
				{
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace",
					"slug": "mono",
					"name": "等幅"
				}
			],
			"fontSizes": [
				{ "slug": "xs",  "size": "0.8125rem", "name": "XS", "fluid": false },
				{ "slug": "sm",  "size": "0.875rem",  "name": "小",  "fluid": { "min": "0.8125rem", "max": "0.9375rem" } },
				{ "slug": "md",  "size": "1rem",      "name": "中",  "fluid": { "min": "0.9375rem", "max": "1.0625rem" } },
				{ "slug": "lg",  "size": "1.25rem",   "name": "大",  "fluid": { "min": "1.125rem",  "max": "1.375rem" } },
				{ "slug": "xl",  "size": "1.5rem",    "name": "XL",  "fluid": { "min": "1.375rem",  "max": "1.75rem" } },
				{ "slug": "2xl", "size": "2rem",      "name": "2XL", "fluid": { "min": "1.75rem",   "max": "2.375rem" } },
				{ "slug": "3xl", "size": "2.5rem",    "name": "3XL", "fluid": { "min": "2rem",      "max": "3rem" } }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem", "name": "XS" },
				{ "slug": "20", "size": "0.75rem","name": "S" },
				{ "slug": "30", "size": "1rem",   "name": "M" },
				{ "slug": "40", "size": "1.5rem", "name": "L" },
				{ "slug": "50", "size": "2rem",   "name": "XL" },
				{ "slug": "60", "size": "3rem",   "name": "2XL" },
				{ "slug": "70", "size": "4rem",   "name": "3XL" }
			]
		},
		"custom": {
			"wa-mode": {
				"description": "和テイスト装飾のON/OFF切替。後続フェーズでブロックスタイル/バリエーションとして追加予定。デフォルトは無効（誰でも使えるシンプルな見た目）。"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--shironeri)",
			"text": "var(--wp--preset--color--sumi)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--gothic)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.8"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--gothic)",
					"fontWeight": "700",
					"lineHeight": "1.4"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--3xl)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--2xl)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--xl)" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--lg)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--ai)" },
				":hover": { "color": { "text": "var(--wp--preset--color--shu)" } }
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--40)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		}
	}
}
